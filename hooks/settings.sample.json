{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/cognosis/hooks/session-start-inject.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/path/to/cognosis/hooks/session-end-nudge.sh"
          }
        ]
      }
    ]
  }
}
